[
  {
    "name": "Falha Funcional (Assercao)",
    "matchedStatuses": [
      "failed"
    ],
    "messageRegex": "(?i).*AssertionFailedError.*|.*expected:.*but was:.*|.*expect.*to.*"
  },
  {
    "name": "Timeout / Espera",
    "matchedStatuses": [
      "broken",
      "failed"
    ],
    "messageRegex": "(?i).*Timeout.*|.*timed out.*|.*waiting for.*|.*waitFor.*"
  },
  {
    "name": "Elemento / Locator",
    "matchedStatuses": [
      "failed",
      "broken"
    ],
    "messageRegex": "(?i).*locator.*|.*strict mode violation.*|.*No node found.*|.*element is not attached.*"
  },
  {
    "name": "Navegacao / Rede",
    "matchedStatuses": [
      "failed",
      "broken"
    ],
    "messageRegex": "(?i).*net::ERR.*|.*DNS.*|.*Connection.*|.*request failed.*|.*ERR_ABORTED.*"
  },
  {
    "name": "Infra de Execucao (CI/Build)",
    "matchedStatuses": [
      "broken"
    ],
    "messageRegex": "(?i).*MojoFailureException.*|.*IOException.*|.*Failed to launch browser.*|.*browserType.launch.*|.*No space left on device.*"
  },
  {
    "name": "Erro Nao Classificado",
    "matchedStatuses": [
      "failed",
      "broken"
    ],
    "messageRegex": "(?i).*Exception.*|.*Error.*"
  }
]
